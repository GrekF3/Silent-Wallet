{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions for Silent Wallet.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "updater:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://app.swallet.site/**" }]
    },
    "stronghold:default"
  ]
}
