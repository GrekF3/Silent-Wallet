{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Silent Wallet",
  "version": "0.1.0",
  "identifier": "app.silent.wallet",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build:app",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Silent Wallet",
        "width": 1180,
        "height": 820,
        "minWidth": 390,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://* http://localhost:*; img-src 'self' data: https://*; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/silent-wallet/silent-wallet/releases/latest/download/latest.json"
      ]
    }
  }
}

