WEB_PORT=9999
ANKR_API_KEY=
COINGECKO_API_KEY=

# Web3 / monetization
NEXT_PUBLIC_ECOSYSTEM_ENABLED=true
NEXT_PUBLIC_SWAP_FEE_BPS=30
NEXT_PUBLIC_LIFI_FEE=0.003

# 0x Swap API
ZEROX_API_KEY=
ZEROX_API_BASE_URL=https://api.0x.org
ZEROX_VERSION=v2
SILENT_FEE_RECIPIENT_ETH=
SILENT_FEE_RECIPIENT_BSC=

# LI.FI
LIFI_API_KEY=
LIFI_INTEGRATOR=silent-wallet

# MoonPay
NEXT_PUBLIC_MOONPAY_ENABLED=false
MOONPAY_ENV=sandbox
MOONPAY_API_KEY=
MOONPAY_SECRET_KEY=

# Transak
NEXT_PUBLIC_TRANSAK_ENABLED=false
TRANSAK_ENV=staging
TRANSAK_API_KEY=
TRANSAK_API_SECRET=
TRANSAK_REFERRER_DOMAIN=

# Optional revenue event logging
REVENUE_EVENT_LOGGING=false

# Public fallback used outside the Tauri updater flow
NEXT_PUBLIC_UPDATE_DOWNLOAD_URL=https://github.com/GrekF3/Silent-Wallet/releases/latest
